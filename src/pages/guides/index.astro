---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';

const guides = [
  {
    title: 'How Much Gravel Do I Need?',
    description: 'Driveway, walkway, and patio examples with exact cubic yard and ton quantities. Includes a depth chart, gravel type comparison, and ordering checklist.',
    href: '/guides/how-much-gravel-do-i-need/',
    tag: 'Gravel',
    calcHref: '/calculators/gravel-calculator/',
  },
];
---

<Layout
  title="Landscaping & Construction Guides | Yard Metric"
  description="Step-by-step material guides for gravel, concrete, mulch, sand, topsoil, and asphalt. Real examples, depth charts, and ordering checklists."
  canonical="https://yardmetric.com/guides/"
>
  <NavBar />

  <main>
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">Material Guides</h1>
        <p class="page-subtitle">In-depth guides for every material we calculate - with worked examples, depth charts, and ordering checklists.</p>
      </div>

      <div class="guides-grid">
        {guides.map((guide) => (
          <a href={guide.href} class="guide-card">
            <span class="guide-tag">{guide.tag}</span>
            <h2 class="guide-title">{guide.title}</h2>
            <p class="guide-desc">{guide.description}</p>
            <span class="guide-cta">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
.container {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 24px;
}

.page-header {
  padding: 56px 0 48px;
}

.page-title {
  font-size: 40px;
  font-weight: 600;
  letter-spacing: -1.6px;
  color: var(--color-ink);
  margin-bottom: 12px;
}

.page-subtitle {
  font-size: 17px;
  color: var(--color-body);
  line-height: 27px;
  max-width: 560px;
}

.guides-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 16px;
  padding-bottom: 80px;
}

.guide-card {
  display: flex;
  flex-direction: column;
  gap: 8px;
  background: var(--color-canvas);
  border-radius: 10px;
  padding: 24px;
  text-decoration: none;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.07);
  transition: all 0.15s;
}
.guide-card:hover {
  box-shadow: 0 0 0 1px rgba(0,0,0,0.12), 0 6px 20px rgba(0,0,0,0.07);
  transform: translateY(-2px);
}

.guide-tag {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-mute);
}

.guide-title {
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.5px;
  color: var(--color-ink);
  line-height: 24px;
}

.guide-desc {
  font-size: 14px;
  color: var(--color-body);
  line-height: 22px;
  flex: 1;
}

.guide-cta {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-link);
  margin-top: 4px;
}

@media (max-width: 600px) {
  .page-title { font-size: 30px; }
  .container { padding: 0 16px; }
  .guides-grid { grid-template-columns: 1fr; }
}
</style>
