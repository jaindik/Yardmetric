---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import Calculator from '../../components/Calculator.astro';
import { calculators, getRelatedCalculators, getPopularCalculators } from '../../data/calculators';
import type { Calculator as CalcType } from '../../data/calculators';

export function getStaticPaths() {
  return calculators.map((c) => ({
    params: { slug: c.slug },
    props: { calculator: c },
  }));
}

interface Props {
  calculator: CalcType;
}

const { calculator } = Astro.props;
const related = getRelatedCalculators(calculator.slug);
const popular = getPopularCalculators(8).filter(c => c.slug !== calculator.slug).slice(0, 6);
const categoryCalcs = calculators
  .filter(c => c.categorySlug === calculator.categorySlug && c.slug !== calculator.slug)
  .slice(0, 6);

const breadcrumb = [
  { name: 'Home', href: '/' },
  { name: calculator.category, href: `/${calculator.categorySlug}/` },
  { name: calculator.name, href: `/calculators/${calculator.slug}/` },
];

const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: calculator.name,
  description: calculator.description,
  url: `https://yardmetric.com/calculators/${calculator.slug}/`,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumb.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: `https://yardmetric.com${b.href}`,
    })),
  },
});

const faqStructuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: calculator.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
});

const howToStructuredData = calculator.howToSteps ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `How to Use the ${calculator.name}`,
  description: calculator.description,
  step: calculator.howToSteps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.name,
    text: s.text,
  })),
}) : null;
---

<Layout
  title={calculator.seoTitle}
  description={calculator.seoDescription}
  canonical={`https://yardmetric.com/calculators/${calculator.slug}/`}
>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={structuredData} />
    <script type="application/ld+json" set:html={faqStructuredData} />
    {howToStructuredData && <script type="application/ld+json" set:html={howToStructuredData} />}
  </Fragment>

  <NavBar />

  <main>
    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          {breadcrumb.map((b, i) => (
            <>
              {i > 0 && <span class="breadcrumb-sep" aria-hidden="true">/</span>}
              {i < breadcrumb.length - 1
                ? <a href={b.href} class="breadcrumb-link">{b.name}</a>
                : <span class="breadcrumb-current" aria-current="page">{b.name}</span>
              }
            </>
          ))}
        </nav>
      </div>
    </div>

    <!-- Hero + Calculator -->
    <section class="calc-hero">
      <div class="container">
        <div class="calc-layout">
          <!-- Left: content -->
          <div class="calc-content">
            <div class="calc-eyebrow">
              <span class="category-badge">{calculator.category}</span>
            </div>
            <h1 class="calc-title">{calculator.name}</h1>
            <p class="calc-subtitle">{calculator.description}</p>
            {calculator.applications && calculator.applications.length > 0 && (
              <div class="learn-block">
                <p class="learn-label">What this page covers:</p>
                <ul class="learn-list">
                  {calculator.applications.map((app) => <li>{app}</li>)}
                </ul>
              </div>
            )}
          </div>

          <!-- Right: calculator widget -->
          <div class="calc-widget-col">
            <Calculator calculator={calculator} />
          </div>
        </div>
      </div>
    </section>

    <!-- SEO Content -->
    <div class="container seo-content">

      <!-- Material Overview -->
      {calculator.materialInfo && (
        <section class="content-section">
          <h2>About {calculator.name.replace(' Calculator', '')}</h2>
          {calculator.materialInfo.split('\n\n').map((para) => (
            <p>{para}</p>
          ))}
        </section>
      )}

      <!-- Common Uses -->
      {calculator.applications && calculator.applications.length > 0 && (
        <section class="content-section">
          <h2>Common Uses</h2>
          <ul class="content-list">
            {calculator.applications.map((app) => <li>{app}</li>)}
          </ul>
        </section>
      )}

      <!-- Professional Tips -->
      {calculator.proTips && calculator.proTips.length > 0 && (
        <section class="content-section">
          <h2>Professional Tips</h2>
          <ul class="content-list">
            {calculator.proTips.map((tip) => <li>{tip}</li>)}
          </ul>
        </section>
      )}

      <!-- Common Mistakes -->
      {calculator.commonMistakes && calculator.commonMistakes.length > 0 && (
        <section class="content-section">
          <h2>Common Mistakes to Avoid</h2>
          <ul class="content-list">
            {calculator.commonMistakes.map((mistake) => <li>{mistake}</li>)}
          </ul>
        </section>
      )}

      <!-- Waste & Ordering -->
      {calculator.wasteFactor && (
        <section class="content-section">
          <h2>Waste &amp; Ordering Recommendation</h2>
          <p>{calculator.wasteFactor}</p>
        </section>
      )}

      <!-- Buying Tips -->
      {calculator.buyingTips && calculator.buyingTips.length > 0 && (
        <section class="content-section">
          <h2>Buying Tips</h2>
          <ul class="content-list">
            {calculator.buyingTips.map((tip) => <li>{tip}</li>)}
          </ul>
        </section>
      )}

      <!-- Formula -->
      <section class="content-section">
        <h2>Formula</h2>
        <div class="formula-block">
          <pre class="formula-code">{calculator.formula}</pre>
        </div>
        <p class="formula-note">{calculator.formulaNote}</p>
        <p class="formula-note" style="margin-top:8px;">
          <a href="/methodology/" class="methodology-link">How we calculate density values and conversion factors →</a>
        </p>
      </section>

      <!-- Examples -->
      {calculator.examples.length > 0 && (
        <section class="content-section">
          <h2>Examples</h2>
          <div class="examples-grid">
            {calculator.examples.map((ex) => (
              <div class="example-card">
                <p class="example-title">{ex.title}</p>
                <div class="example-dims">
                  <span>{ex.length} × {ex.width} {ex.unit}</span>
                  {ex.depth > 0 && <span>× {ex.depth}" deep</span>}
                </div>
                {ex.result && <p class="example-result">= {ex.result}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- FAQ -->
      <section class="content-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          {calculator.faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-q">{faq.q}</summary>
              <p class="faq-a">{faq.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Related Guides -->
      {calculator.guides && calculator.guides.length > 0 && (
        <section class="content-section">
          <h2>Related Guides</h2>
          <div class="guides-list">
            {calculator.guides.map((guide) => (
              guide.href
                ? <a href={guide.href} class="guide-link">{guide.title} →</a>
                : <span class="guide-link guide-link--soon">{guide.title} <span class="coming-soon">coming soon</span></span>
            ))}
          </div>
        </section>
      )}

      <!-- Related calculators -->
      {related.length > 0 && (
        <section class="content-section">
          <h2>Related Calculators</h2>
          <div class="related-grid">
            {related.map((rel) => (
              <a href={`/calculators/${rel.slug}/`} class="related-card">
                <span class="related-icon" aria-hidden="true">{rel.icon}</span>
                <div>
                  <p class="related-name">{rel.name}</p>
                  <p class="related-desc">{rel.shortDesc}</p>
                </div>
                <svg class="related-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M3 7h8M7.5 3.5 11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- More in this category -->
      {categoryCalcs.length > 0 && (
        <section class="content-section">
          <h2>More {calculator.category} Calculators</h2>
          <div class="related-grid">
            {categoryCalcs.map((c) => (
              <a href={`/calculators/${c.slug}/`} class="related-card">
                <span class="related-icon" aria-hidden="true">{c.icon}</span>
                <div>
                  <p class="related-name">{c.name}</p>
                  <p class="related-desc">{c.shortDesc}</p>
                </div>
                <svg class="related-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M3 7h8M7.5 3.5 11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ))}
          </div>
          <p class="section-all-link">
            <a href={`/${calculator.categorySlug}/`}>View all {calculator.category} calculators →</a>
          </p>
        </section>
      )}

      <!-- Popular calculators -->
      {popular.length > 0 && (
        <section class="content-section">
          <h2>Popular Calculators</h2>
          <div class="popular-grid">
            {popular.map((c) => (
              <a href={`/calculators/${c.slug}/`} class="popular-card">
                <span class="popular-icon" aria-hidden="true">{c.icon}</span>
                <div>
                  <p class="popular-name">{c.name}</p>
                  <p class="popular-cat">{c.category}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer />
</Layout>

<style>
.breadcrumb-bar {
  background: var(--color-canvas);
  border-bottom: 1px solid var(--color-hairline);
  padding: 10px 0;
}
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--color-mute);
}
.breadcrumb-link {
  color: var(--color-body);
  text-decoration: none;
  transition: color 0.15s;
}
.breadcrumb-link:hover { color: var(--color-ink); }
.breadcrumb-current { color: var(--color-ink); font-weight: 500; }
.breadcrumb-sep { color: var(--color-hairline-strong); }

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.calc-hero {
  padding: 48px 0 64px;
  background: var(--color-canvas);
  border-bottom: 1px solid var(--color-hairline);
}

.calc-layout {
  display: grid;
  grid-template-columns: 1fr 480px;
  gap: 48px;
  align-items: start;
}

.calc-eyebrow {
  margin-bottom: 12px;
}
.category-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  background: var(--color-canvas-soft-2);
  color: var(--color-body);
  font-family: var(--font-mono);
  font-size: 11px;
  border-radius: 100px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.calc-title {
  font-size: 40px;
  font-weight: 600;
  line-height: 44px;
  letter-spacing: -1.6px;
  color: var(--color-ink);
  margin-bottom: 16px;
}

.calc-subtitle {
  font-size: 16px;
  color: var(--color-body);
  line-height: 26px;
  max-width: 480px;
}

.seo-content {
  padding-top: 64px;
  padding-bottom: 80px;
}

.content-section {
  margin-bottom: 56px;
}
.content-section h2 {
  font-size: 24px;
  font-weight: 600;
  letter-spacing: -0.96px;
  color: var(--color-ink);
  margin-bottom: 16px;
}
.content-section p {
  font-size: 16px;
  color: var(--color-body);
  line-height: 26px;
  margin-bottom: 12px;
  max-width: 720px;
}

.formula-block {
  background: var(--color-ink);
  border-radius: 8px;
  padding: 20px 24px;
  margin-bottom: 12px;
  overflow-x: auto;
}
.formula-code {
  font-family: var(--font-mono);
  font-size: 13px;
  color: #e5e5e5;
  line-height: 1.8;
  white-space: pre-wrap;
  margin: 0;
}
.formula-note {
  font-size: 13px;
  color: var(--color-mute);
  line-height: 20px;
  max-width: 640px;
}

.content-list {
  margin: 0;
  padding: 0 0 0 20px;
  max-width: 720px;
}
.content-list li {
  font-size: 16px;
  color: var(--color-body);
  line-height: 26px;
  margin-bottom: 8px;
}

.examples-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.example-card {
  background: var(--color-canvas);
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.07);
}
.example-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-ink);
  margin-bottom: 6px;
  letter-spacing: -0.3px;
}
.example-dims {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}
.example-dims span {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-mute);
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.07);
  max-width: 720px;
}
.faq-item {
  background: var(--color-canvas);
  border-bottom: 1px solid var(--color-hairline);
}
.faq-item:last-child {
  border-bottom: none;
}
.faq-q {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  font-size: 15px;
  font-weight: 500;
  color: var(--color-ink);
  cursor: pointer;
  list-style: none;
  letter-spacing: -0.3px;
  transition: background 0.15s;
}
.faq-q:hover { background: var(--color-canvas-soft); }
.faq-q::-webkit-details-marker { display: none; }
.faq-q::after {
  content: '+';
  font-size: 18px;
  color: var(--color-mute);
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 12px;
  transition: transform 0.2s;
}
details[open] .faq-q::after {
  transform: rotate(45deg);
}
.faq-a {
  padding: 0 20px 16px;
  font-size: 14px;
  color: var(--color-body);
  line-height: 22px;
  max-width: 640px;
  margin: 0;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 10px;
}
.related-card {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--color-canvas);
  border-radius: 8px;
  padding: 14px 16px;
  text-decoration: none;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.07);
  transition: all 0.15s;
}
.related-card:hover {
  box-shadow: 0 0 0 1px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
  transform: translateY(-1px);
}
.related-icon {
  font-size: 20px;
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-canvas-soft-2);
  border-radius: 6px;
}
.related-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-ink);
  letter-spacing: -0.3px;
  margin-bottom: 2px;
}
.related-desc {
  font-size: 12px;
  color: var(--color-mute);
  line-height: 16px;
}
.related-arrow {
  color: var(--color-mute);
  margin-left: auto;
  flex-shrink: 0;
}

.section-all-link {
  margin-top: 12px;
}
.section-all-link a {
  font-size: 13px;
  color: var(--color-link);
  text-decoration: none;
  font-weight: 500;
}
.section-all-link a:hover { text-decoration: underline; }

.popular-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 8px;
}
.popular-card {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--color-canvas);
  border-radius: 8px;
  padding: 12px 14px;
  text-decoration: none;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.06);
  transition: all 0.15s;
}
.popular-card:hover {
  box-shadow: 0 0 0 1px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.05);
}
.popular-icon {
  font-size: 16px;
  width: 30px;
  height: 30px;
  background: var(--color-canvas-soft-2);
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.popular-name { font-size: 13px; font-weight: 600; color: var(--color-ink); letter-spacing: -0.2px; margin-bottom: 2px; }
.popular-cat { font-size: 11px; color: var(--color-mute); }

.learn-block {
  margin-top: 20px;
  padding: 16px 20px;
  background: var(--color-canvas-soft);
  border-left: 3px solid var(--color-ink);
  border-radius: 0 6px 6px 0;
  max-width: 480px;
}
.learn-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-mute);
  margin-bottom: 8px;
}
.learn-list {
  margin: 0;
  padding: 0 0 0 16px;
}
.learn-list li {
  font-size: 13px;
  color: var(--color-body);
  line-height: 22px;
  margin-bottom: 2px;
}

.example-result {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-ink);
  font-weight: 600;
  margin: 6px 0 0;
  padding-top: 6px;
  border-top: 1px solid var(--color-hairline);
}

.methodology-link {
  color: var(--color-link);
  text-decoration: none;
  font-size: 13px;
}
.methodology-link:hover { text-decoration: underline; }

.guides-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-width: 560px;
}
.guide-link {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  font-weight: 500;
  color: var(--color-link);
  text-decoration: none;
  padding: 12px 16px;
  background: var(--color-canvas);
  border-radius: 8px;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.07);
  transition: all 0.15s;
}
.guide-link:hover {
  box-shadow: 0 0 0 1px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
  transform: translateY(-1px);
  text-decoration: none;
}
.guide-link--soon {
  color: var(--color-mute);
  cursor: default;
}
.guide-link--soon:hover {
  box-shadow: 0 0 0 1px rgba(0,0,0,0.07);
  transform: none;
}
.coming-soon {
  font-size: 11px;
  font-weight: 400;
  color: var(--color-mute);
  background: var(--color-canvas-soft-2);
  padding: 2px 6px;
  border-radius: 100px;
  letter-spacing: 0.03em;
}

@media (max-width: 900px) {
  .calc-layout {
    grid-template-columns: 1fr;
  }
  .calc-title { font-size: 32px; letter-spacing: -1.2px; }
  .examples-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .calc-hero { padding: 32px 0 40px; }
  .container { padding: 0 16px; }
  .calc-title { font-size: 28px; letter-spacing: -0.8px; }
  .examples-grid { grid-template-columns: 1fr; }
}

/* ── Dark mode overrides ──────────────────────────────────────────── */
@media (prefers-color-scheme: dark) {
  /* Formula block: var(--color-ink) becomes light in dark mode, override to a dark surface */
  :global(html:not([data-theme="light"])) .formula-block {
    background: var(--color-canvas-soft-2);
    border: 1px solid var(--color-hairline);
  }
  :global(html:not([data-theme="light"])) .formula-code { color: #d4d4d4; }
  :global(html:not([data-theme="light"])) .example-card { box-shadow: 0 0 0 1px rgba(255,255,255,0.07); }
  :global(html:not([data-theme="light"])) .faq-list { box-shadow: 0 0 0 1px rgba(255,255,255,0.07); }
  :global(html:not([data-theme="light"])) .related-card { box-shadow: 0 0 0 1px rgba(255,255,255,0.07); }
  :global(html:not([data-theme="light"])) .related-card:hover { box-shadow: 0 0 0 1px rgba(255,255,255,0.13), 0 4px 12px rgba(0,0,0,0.5); }
  :global(html:not([data-theme="light"])) .popular-card { box-shadow: 0 0 0 1px rgba(255,255,255,0.06); }
  :global(html:not([data-theme="light"])) .popular-card:hover { box-shadow: 0 0 0 1px rgba(255,255,255,0.10), 0 2px 8px rgba(0,0,0,0.4); }
}
:global(html[data-theme="dark"]) .formula-block {
  background: var(--color-canvas-soft-2);
  border: 1px solid var(--color-hairline);
}
:global(html[data-theme="dark"]) .formula-code { color: #d4d4d4; }
:global(html[data-theme="dark"]) .example-card { box-shadow: 0 0 0 1px rgba(255,255,255,0.07); }
:global(html[data-theme="dark"]) .faq-list { box-shadow: 0 0 0 1px rgba(255,255,255,0.07); }
