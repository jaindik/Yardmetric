---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Fast, accurate calculators for gravel, sand, mulch, topsoil, concrete, asphalt, lumber and more. Free material calculators for construction, landscaping, and DIY projects.',
  canonical,
  ogImage = '/ogImage.png',
  noindex = false,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title.includes('Yard Metric') ? title : `${title} | Yard Metric`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Anti-FOUC: apply theme before first paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', stored || system);
        } catch (_) {}
      })();
    </script>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content="Yard Metric" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Google Analytics (deferred - loaded after page is interactive) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-D3E0MCKRZT');
      window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-D3E0MCKRZT';
        s.async = true;
        document.head.appendChild(s);
      });
    </script>

    <!-- Organization Schema (site-wide) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Yard Metric",
      "url": "https://yardmetric.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://yardmetric.com/favicon.ico"
      },
      "description": "Free material calculators for construction and landscaping. Calculate gravel, sand, mulch, topsoil, concrete, asphalt, lumber, and more."
    }
    </script>

    <!-- Ahrefs Analytics -->
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="EndS5QUuPYmLtHpQYo+1EQ" async is:inline></script>

    <!-- JSON-LD Structured Data -->
    <slot name="structured-data" />
  </head>
  <body>
    <slot />
  </body>
</html>
