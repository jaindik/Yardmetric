---
const navLinks = [
  { href: '/landscaping/', label: 'Landscaping' },
  { href: '/construction/', label: 'Construction' },
  { href: '/pavers-outdoor/', label: 'Pavers & Outdoor' },
  { href: '/lumber-woodworking/', label: 'Lumber' },
];
const currentPath = Astro.url.pathname;
---

<header class="nav-bar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Yard Metric home">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="8" height="8" rx="1.5" fill="currentColor"/>
        <rect x="12" width="8" height="8" rx="1.5" fill="currentColor" opacity=".4"/>
        <rect y="12" width="8" height="8" rx="1.5" fill="currentColor" opacity=".4"/>
        <rect x="12" y="12" width="8" height="8" rx="1.5" fill="currentColor" opacity=".7"/>
      </svg>
      <span class="nav-logo-text">Yard Metric</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { 'nav-link-active': currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Switch to dark mode">
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M13.5 9A5.5 5.5 0 0 1 7 2.5a.5.5 0 0 0-.6-.6A6 6 0 1 0 14.1 9.6a.5.5 0 0 0-.6-.6Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      </svg>
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.25"/>
        <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M12.6 3.4l-1.07 1.07M4.47 11.53l-1.07 1.07" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
    </button>

    <button class="nav-mobile-toggle" id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect y="3" width="16" height="1.5" rx=".75" fill="currentColor"/>
        <rect y="7.25" width="16" height="1.5" rx=".75" fill="currentColor"/>
        <rect y="11.5" width="16" height="1.5" rx=".75" fill="currentColor"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Mobile navigation" hidden>
    <nav class="mobile-nav">
      <a href="/" class="mobile-nav-link">Home</a>
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-nav-link">{link.label}</a>
      ))}
      <div class="mobile-nav-divider" aria-hidden="true"></div>
      <a href="/about/" class="mobile-nav-link mobile-nav-link-muted">About</a>
      <a href="/contact/" class="mobile-nav-link mobile-nav-link-muted">Contact</a>
    </nav>
  </div>
</header>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    height: 64px;
    display: flex;
    flex-direction: column;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 64px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--color-ink);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.28px;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 400;
    color: var(--color-body);
    text-decoration: none;
    letter-spacing: -0.28px;
    transition: background 0.15s, color 0.15s;
  }

  .nav-link:hover {
    background: var(--color-canvas-soft-2);
    color: var(--color-ink);
  }

  .nav-link-active {
    color: var(--color-ink);
    font-weight: 500;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-body);
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s;
  }
  .theme-toggle:hover {
    background: var(--color-canvas-soft-2);
    color: var(--color-ink);
  }

  /* Moon shown by default (light mode) */
  .icon-sun { display: none; }

  /* Dark mode: show sun, hide moon */
  @media (prefers-color-scheme: dark) {
    :global(html:not([data-theme="light"])) .icon-moon { display: none; }
    :global(html:not([data-theme="light"])) .icon-sun { display: flex; }
  }
  :global(html[data-theme="dark"]) .icon-moon { display: none; }
  :global(html[data-theme="dark"]) .icon-sun { display: flex; }
  :global(html[data-theme="light"]) .icon-moon { display: flex; }
  :global(html[data-theme="light"]) .icon-sun { display: none; }

  .nav-mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-ink);
    margin-left: auto;
  }

  .mobile-menu {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: 8px 16px 16px;
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-nav-link {
    display: block;
    padding: 10px 12px;
    border-radius: 6px;
    font-size: 15px;
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 400;
  }

  .mobile-nav-link:hover {
    background: var(--color-canvas-soft-2);
  }

  .mobile-nav-divider {
    height: 1px;
    background: var(--color-hairline);
    margin: 4px 0;
  }

  .mobile-nav-link-muted {
    color: var(--color-body);
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .nav-mobile-toggle {
      display: flex;
    }
    .nav-bar {
      height: auto;
      min-height: 56px;
    }
    .nav-inner {
      height: 56px;
      padding: 0 16px;
    }
  }
</style>

<script>
  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.hidden;
      menu.hidden = isOpen;
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  function getCurrentTheme(): string {
    return document.documentElement.getAttribute('data-theme') || 'light';
  }
  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    try { localStorage.setItem('theme', theme); } catch (_) {}
    if (themeToggle) {
      themeToggle.setAttribute(
        'aria-label',
        theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'
      );
    }
  }
  themeToggle?.addEventListener('click', () => {
    applyTheme(getCurrentTheme() === 'dark' ? 'light' : 'dark');
  });
  // Set initial aria-label based on current theme
  if (themeToggle) {
    applyTheme(getCurrentTheme());
  }
</script>
