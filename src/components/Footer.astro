---
import { categories, calculators } from '../data/calculators';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="8" height="8" rx="1.5" fill="currentColor"/>
          <rect x="12" width="8" height="8" rx="1.5" fill="currentColor" opacity=".4"/>
          <rect y="12" width="8" height="8" rx="1.5" fill="currentColor" opacity=".4"/>
          <rect x="12" y="12" width="8" height="8" rx="1.5" fill="currentColor" opacity=".7"/>
        </svg>
        <span>Yard Metric</span>
      </a>
      <p class="footer-tagline">Free, accurate material calculators for construction, landscaping, and DIY projects.</p>
    </div>

    {categories.map((cat) => (
      <div class="footer-col">
        <p class="footer-col-label">{cat.name}</p>
        <ul class="footer-col-links">
          {calculators
            .filter((c) => c.categorySlug === cat.slug)
            .slice(0, 6)
            .map((c) => (
              <li>
                <a href={`/calculators/${c.slug}/`}>{c.name}</a>
              </li>
            ))}
          <li>
            <a href={`/${cat.slug}/`}>All {cat.name} →</a>
          </li>
        </ul>
      </div>
    ))}
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">© {new Date().getFullYear()} Yard Metric. All calculators are provided for estimation purposes only.</p>
      <nav class="footer-legal" aria-label="Legal">
        <a href="/guides/">Guides</a>
        <a href="/methodology/">Methodology</a>
        <a href="/about/">About</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="/contact/">Contact</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    margin-top: 80px;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 64px 24px 40px;
    display: grid;
    grid-template-columns: 240px repeat(4, 1fr);
    gap: 32px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
    letter-spacing: -0.28px;
    margin-bottom: 12px;
  }

  .footer-tagline {
    font-size: 13px;
    color: var(--color-mute);
    line-height: 20px;
    max-width: 200px;
  }

  .footer-col-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }

  .footer-col-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-col-links a {
    font-size: 13px;
    color: var(--color-body);
    text-decoration: none;
    line-height: 20px;
    letter-spacing: -0.2px;
    transition: color 0.15s;
  }

  .footer-col-links a:hover {
    color: var(--color-ink);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-hairline);
  }

  .footer-bottom-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--color-mute);
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-legal a {
    font-size: 12px;
    color: var(--color-mute);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-legal a:hover {
    color: var(--color-body);
  }

  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      padding: 40px 16px 24px;
      gap: 24px;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>
